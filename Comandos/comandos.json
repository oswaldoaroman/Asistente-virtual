{
  "SONIDO": {
    "sube volumen": ["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", "5%+"],
    "baja volumen": ["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", "5%-"],
    "silencio": ["wpctl", "set-mute", "@DEFAULT_AUDIO_SINK@", "toggle"]
  },

  "MULTIMEDIA":{
    "siguiente cancion": ["playerctl","next"],
    "cancion anterior": ["playerctl","previous"],
    "pausa":["playerctl","pause"],
    "reanuda":["playerctl","play"]
  },

  "LANZARAPP": {
    "abre el navegador": ["systemd-run", "--user", "librewolf"],
    "abre terminal": ["systemd-run", "--user", "kitty"],
    "abre spotify": ["systemd-run", "--user", "spotify-launcher"],
    "abre discord": ["systemd-run", "--user", "discord"],
    "abre whatsapp": ["systemd-run", "--user", "chromium", "--app=https://web.whatsapp.com/"],
    "abre youtube": ["systemd-run", "--user", "chromium", "--app=https://www.youtube.com/"],
    "abre ia": ["systemd-run", "--user", "chromium", "--app=https://chat.openai.com/"],
    "abre git": ["systemd-run", "--user", "chromium", "--app=https://github.com/"]
  }
}
