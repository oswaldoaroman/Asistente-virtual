  "SONIDO": {
    "sube volumen": ["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", "5%+"],
    "baja volumen": ["wpctl", "set-volume", "@DEFAULT_AUDIO_SINK@", "5%-"],
    "silencio": ["wpctl", "set-mute", "@DEFAULT_AUDIO_SINK@", "toggle"]
  },

  "MULTIMEDIA":{
    "siguiente cancion": ["playerctl","next"],
    "cancion anterior": ["playerctl","previous"],
    "pausa":["playerctl","pause"],
    "reanuda":["playerctl","play"]
  },

